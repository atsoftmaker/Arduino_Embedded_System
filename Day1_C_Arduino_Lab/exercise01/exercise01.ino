void setup() {
  // เปิดการเชื่อมต่อเพื่อส่งข้อมูลไปแสดงบนจอคอมพิวเตอร์ด้วยความเร็ว 9600
  Serial.begin(9600);
  
  // ---------------------------------------------------------
  // 1. กลุ่มตัวเลขจำนวนเต็ม (Integer & Byte)
  // ---------------------------------------------------------
  int myAge = 25;               // int: เก็บจำนวนเต็มทั่วไป (มักใช้บ่อยสุด)
  long bigNumber = 1500000;     // long: เก็บจำนวนเต็มที่ค่าเยอะมากๆ
  byte ledPin = 13;             // byte: เก็บเลข 0-255 (ประหยัดพื้นที่หน่วยความจำ นิยมใช้ระบุขาพิน)

  // ---------------------------------------------------------
  // 2. กลุ่มตัวเลขทศนิยม (Floating Point)
  // ---------------------------------------------------------
  float myWeight = 65.5;        // float: ทศนิยมทั่วไป (แม่นยำประมาณ 6-7 หลัก)
  double precisePi = 3.14159;   // double: ทศนิยมที่ต้องการความแม่นยำ (ในบอร์ด Uno/Nano จะมีค่าเท่ากับ float)

  // ---------------------------------------------------------
  // 3. กลุ่มตัวอักษรและข้อความ (Character & String)
  // ---------------------------------------------------------
  char myGrade = 'A';           // char: เก็บตัวอักษร "แค่ตัวเดียว" (ต้องใช้เครื่องหมาย ' ' ขีดเดียว)
  String myName = "Arduino";    // String: เก็บข้อความยาวๆ (ต้องใช้เครื่องหมาย "  " สองขีด)

  // ---------------------------------------------------------
  // 4. กลุ่มตรรกะ (Boolean)
  // ---------------------------------------------------------
  bool isReady = true;          // bool: เก็บค่าความจริง มีแค่ true (1) กับ false (0)


  // =========================================================
  // ส่วนของการแสดงผล (Print ออกมาดูทีละบรรทัด)
  // =========================================================
  Serial.println("--- เริ่มการทดสอบตัวแปร ---");
  
  Serial.print("1. ชื่อของฉันคือ (String): ");
  Serial.println(myName);
  
  Serial.print("2. อายุ (int): ");
  Serial.println(myAge);

  Serial.print("3. น้ำหนัก (float): ");
  Serial.println(myWeight);
  
  Serial.print("4. เกรดที่ได้ (char): ");
  Serial.println(myGrade);
  
  Serial.print("5. ขาพิน LED (byte): ");
  Serial.println(ledPin);
  
  Serial.print("6. ค่า Pi (double): ");
  Serial.println(precisePi);
  
  Serial.print("7. ตัวเลขขนาดใหญ่ (long): ");
  Serial.println(bigNumber);
  
  Serial.print("8. สถานะความพร้อม (bool): ");
  Serial.println(isReady); // จะปริ้นออกมาเป็นเลข 1 (true) หรือ 0 (false)
  
  Serial.println("-------------------------");
}

void loop() {}

